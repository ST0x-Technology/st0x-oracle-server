# Placeholder for `secrets/st0x-oracle-diff-observer-env.age`. The
# observer talks to two open `/context/v1` endpoints — neither side
# requires authentication — so the only thing in this env file is the
# log level. The systemd unit's `EnvironmentFile=` still wants the
# file to exist, so we ship an encrypted blob with a single line:
#
#   RUST_LOG=st0x_oracle_diff_observer=info,warn
#
# Create with:
#
#   echo 'RUST_LOG=st0x_oracle_diff_observer=info,warn' > /tmp/st0x-oracle-diff-observer-env
#
#   nix eval --raw --file ../keys.nix roles.ssh \
#     --apply 'builtins.concatStringsSep "\n"' \
#     | rage -e -R /dev/stdin -o secrets/st0x-oracle-diff-observer-env.age /tmp/st0x-oracle-diff-observer-env
#
#   rm /tmp/st0x-oracle-diff-observer-env
