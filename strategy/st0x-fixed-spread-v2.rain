version: 6

orders:
  base:
    raindex: base
    oracle-url: https://st0x-oracle-server.fly.dev/context/v2
    inputs:
      - token: input
    outputs:
      - token: output

scenarios:
  st0x-oracle-baseline-base-v2:
    raindex: base
    rainlang: base
    runs: 1
    bindings:
      raindex-subparser: 0x22839F16281E67E5Fd395fAFd1571e820CbD46cB
      oracle-signer: 0x8Ff1CA8ED2e98f693A3eA16b3EBE44FE90500A43
      oracle-schema-version: 2

deployments:
  base-st0x-v2:
    order: base
    scenario: st0x-oracle-baseline-base-v2

builder:
  name: St0x fixed spread limit v2
  description: https://raw.githubusercontent.com/rainlanguage/rain.strategies/e25bc4876b5ffb8bb28097b0ca66de291c75ff56/src/fixed-spread.md
  short-description: >
    A strategy where the ratio tracks a benchmark price with a fixed
    multiplier, gated on market session via the v2 oracle endpoint.
  deployments:
    base-st0x-v2:
      name: Base st0x fixed spread v2
      description: Deploy a fixed-spread strategy on Base using St0x v2 price feeds, restricted to a specific market session.
      deposits:
        - token: output
      fields:
        - binding: allowed-session
          name: Market session
          description: >
            Which market session this strategy will quote during. The
            v2 oracle signs the current session into the context;
            orders revert when the signed session does not match.
            Values are Rain IntOrAString-encoded bytes32 (same format
            as Pyth pair presets in rain.strategies).
          default: 0x8372746800000000000000000000000000000000000000000000000000000000
          presets:
            - name: Regular trading hours (09:30-16:00 ET)
              value: 0x8372746800000000000000000000000000000000000000000000000000000000
            - name: Pre-market (04:00-09:30 ET)
              value: 0x897072656d61726b657400000000000000000000000000000000000000000000
            - name: After-hours (16:00-20:00 ET)
              value: 0x8a6166746572686f757273000000000000000000000000000000000000000000
        - binding: baseline-multiplier
          name: Benchmark price multiplier
          description: |
            The multiplier to be applied to the benchmark when calculating the price the strategy will offer at
          show-custom-field: true
          default: 1.001
          presets:
            - name: 1.001x
              value: 1.001
            - name: 1.005x
              value: 1.005
            - name: 1.0025x
              value: 1.0025
        - binding: min-price
          name: Minimum Price
          description: >
            Floor price as a safety guard. If the oracle returns a price
            below this, the order reverts. Protects against catastrophic
            mispricings or broken oracle data. Set based on the asset -
            e.g. 0.01 for penny stocks, 10 for blue chips.
          default: 0.01
          min: 0.000001
        - binding: max-price
          name: Maximum Price
          description: >
            Ceiling price as a safety guard. If the oracle returns a
            price above this, the order reverts. Protects against
            overflow or encoding errors. Set generously above the
            asset's expected range.
          default: 100000
          min: 1
      select-tokens:
        - key: output
          name: Token to Sell
          description: Select the token you want to sell
        - key: input
          name: Token to Buy
          description: Select the token you want to purchase
---
#raindex-subparser !Raindex subparser.

#oracle-signer !The trusted signer address for the st0x oracle server.
#baseline-multiplier !WAD multiplier to apply to the baseline (e.g. 1.001).
#oracle-schema-version !Expected oracle context schema version (= 2 for v2).
#allowed-session !Required market-session tag as Rain IntOrAString bytes32 (hex). Must match oracle context slot 3.
#min-price !Minimum acceptable oracle price. Orders revert below this. Catches catastrophic mispricings.
#max-price !Maximum acceptable oracle price. Orders revert above this. Catches overflow or encoding errors.


#st0x-oracle-baseline-v2
  /* Verify the signed context comes from the trusted st0x oracle signer */
  :ensure(
    equal-to(signer<0>() oracle-signer)
    "Untrusted oracle signer"
  ),

  /* Schema version guard
  * If the server ever changes the v2 layout, live orders must
  * revert instead of misreading slots. */
  oracle-version: signed-context<0 0>(),
  :ensure(
    equal-to(oracle-version oracle-schema-version)
    "Oracle schema version mismatch"
  ),

  /* Read oracle price from signed context column 0, row 1 */
  oracle-price: signed-context<0 1>(),

  /* Read the market session this quote was signed during. */
  oracle-session: signed-context<0 3>(),

  /* Read the UTC start and end of that current session. */
  oracle-session-start: signed-context<0 4>(),
  oracle-session-end: signed-context<0 5>(),

  /* Session guard. Strategy only operates in the deployer-chosen session.
   * The oracle signs the session as Rain IntOrAString bytes32 in slot 3;
   * bind `allowed-session` to the same hex encoding (see builder presets). */
  :ensure(
    equal-to(oracle-session allowed-session)
    "Not in allowed market session"
  ),

  /* Chain-time bounds: block.timestamp must fall inside the session
   * window the oracle stamped. */
  :ensure(
    greater-than-or-equal-to(now() oracle-session-start)
    "Before session start"
  ),
  :ensure(
    less-than-or-equal-to(now() oracle-session-end)
    "After session end"
  ),

  /*
   * SAFETY GUARDS
   * These protect against bugs, malformed oracle data, or server mishaps.
   * They are NOT market risk controls - session gating already handles that.
   */

  /* Guard: zero ratio */
  :ensure(
    greater-than(oracle-price 0)
    "Oracle price is zero"
  ),

  /* Guard: minimum price bound */
  :ensure(
    greater-than(oracle-price min-price)
    "Price below minimum bound"
  ),

  /* Guard: maximum price bound */
  :ensure(
    less-than(oracle-price max-price)
    "Price above maximum bound"
  ),
  _: oracle-price;

#calculate-io
using-words-from raindex-subparser
offer-amount: max-positive-value(),
io: mul(call<'st0x-oracle-baseline-v2>() baseline-multiplier);

#handle-io
:;

#handle-add-order
:;
