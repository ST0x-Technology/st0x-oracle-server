version: 6

orders:
  base:
    raindex: base
    oracle-url: https://oracle.t0trade.com/context/v4
    inputs:
      - token: token1
    outputs:
      - token: token2

scenarios:
  base:
    raindex: base
    rainlang: base
    runs: 1
    bindings:
      raindex-subparser: 0x22839F16281E67E5Fd395fAFd1571e820CbD46cB
      oracle-signer: 0x8Ff1CA8ED2e98f693A3eA16b3EBE44FE90500A43
      oracle-schema-version: 4

deployments:
  base:
    order: base
    scenario: base

builder:
  name: st0x Oracle Limit v4
  description: >
    A limit order for st0x tokenized equities that uses the st0x oracle
    server's v4 endpoint. Same behaviour as v3 (signed session tag +
    session-window guard + min/max price bounds) plus an explicit binding
    of the signed price to a specific token pair. Every quote is signed
    against a `(input_token, output_token)` pair the caller nominated,
    and this order asserts those match the running order's IO addresses
    byte-for-byte — so a signed frame for pair (A,B) cannot be replayed
    against an order whose IO is (C,D), even if both prices happen to
    fit the same min/max band.

    The oracle automatically returns the correct price direction:
    - Buy tStock (input USDC, output tStock): ask price
    - Sell tStock (input tStock, output USDC): 1/bid price
  short-description: A limit order for tStocks priced at real-time Alpaca NBBO via signed context oracle, gated on market session and pair-bound.
  deployments:
    base:
      name: Base
      description: Deploy an oracle-priced tStock limit order on Base, restricted to a specific market session, pair-bound to the deployed IO pair.
      deposits:
        - token: token2
      fields:
        - binding: allowed-session
          name: Market session
          description: >
            Which market session this strategy will quote during. The
            v4 oracle signs the current session into the context;
            orders revert when the signed session does not match.
          default: '"rth"'
          presets:
            - name: Regular trading hours (09:30-16:00 ET)
              value: '"rth"'
            - name: Pre-market (04:00-09:30 ET)
              value: '"premarket"'
            - name: After-hours (16:00-20:00 ET)
              value: '"afterhours"'
        - binding: min-price
          name: Minimum Price
          description: >
            Floor price as a safety guard. If the oracle returns a price
            below this, the order reverts. Protects against catastrophic
            mispricings or broken oracle data. Set based on the asset -
            e.g. 0.01 for penny stocks, 10 for blue chips.
          default: 0.01
          min: 0.000001
        - binding: max-price
          name: Maximum Price
          description: >
            Ceiling price as a safety guard. If the oracle returns a
            price above this, the order reverts. Protects against
            overflow or encoding errors. Set generously above the
            asset's expected range.
          default: 100000
          min: 1
      select-tokens:
        - key: token1
          name: Token to Buy
          description: Select the token you want to purchase (e.g. wtCOIN, USDC)
        - key: token2
          name: Token to Sell
          description: Select the token you want to sell (e.g. wtCOIN, USDC)

---
#raindex-subparser !The subparser to use.

#oracle-signer !The trusted signer address for the st0x oracle server.
#oracle-schema-version !Expected oracle context schema version (= 4 for v4).
#allowed-session !Required market-session tag (Rain string literal). One of "rth", "premarket", "afterhours". Must match oracle context slot 3.

#min-price !Minimum acceptable oracle price. Orders revert below this. Catches catastrophic mispricings.
#max-price !Maximum acceptable oracle price. Orders revert above this. Catches overflow or encoding errors.

#calculate-io
using-words-from raindex-subparser

/* Verify the signed context comes from the trusted st0x oracle signer. */
:ensure(
  equal-to(signer<0>() oracle-signer)
  "Untrusted oracle signer"
),

/* Schema version guard. If the server ever changes the v4 layout this
 * order must revert instead of misreading slots. */
oracle-version: signed-context<0 0>(),
:ensure(
  equal-to(oracle-version oracle-schema-version)
  "Oracle schema version mismatch"
),

/* Read oracle price from signed context column 0, row 1. */
oracle-price: signed-context<0 1>(),

/* Read the source timestamp for the signed price. */
oracle-publish-time: signed-context<0 2>(),

/* Read the market session this quote was signed during (Rain
 * IntOrAString V3 bytes32; matches what `"…"` literals parse to).
 * Used by the session guard below. */
oracle-session: signed-context<0 3>(),

/* Read the UTC start and end of that current session. */
oracle-session-start: signed-context<0 4>(),
oracle-session-end: signed-context<0 5>(),

/* Read the input/output token addresses the signer committed this
 * price to. Both are Address values in bytes32 (left-padded with 12
 * zero bytes) matching Ethereum's Address→bytes32 convention. */
oracle-input-token: signed-context<0 6>(),
oracle-output-token: signed-context<0 7>(),

/* PAIR BIND: the whole reason v4 exists. Assert the signed frame
 * targets THIS order's IO pair. Without this check, a valid signed
 * frame for pair (A,B) could be replayed against an order whose IO
 * is (C,D) whenever the min/max price bands overlap. `input-token()`
 * and `output-token()` are the raindex subparser context words that
 * expose the current order's IO addresses at execution time. */
:ensure(
  equal-to(oracle-input-token input-token())
  "Oracle input token mismatch"
),
:ensure(
  equal-to(oracle-output-token output-token())
  "Oracle output token mismatch"
),

/* Session guard. Strategy only operates in the deployer-chosen session.
 * The oracle signs the session as Rain IntOrAString V3 bytes32 in
 * slot 3, matching the on-the-wire bytes32 a Rainlang `"…"` string
 * literal parses to — so the user-bound `allowed-session` is just
 * `"rth"` / `"premarket"` / `"afterhours"`. */
:ensure(
  equal-to(oracle-session allowed-session)
  "Not in allowed market session"
),

/* Chain-time bounds: block.timestamp must fall inside the session
 * window the oracle stamped. If block.timestamp is past
 * `oracle-session-end` the session is over (or the oracle's cached
 * calendar is stale) and we revert. */
:ensure(
  greater-than-or-equal-to(now() oracle-session-start)
  "Before session start"
),
:ensure(
  less-than-or-equal-to(now() oracle-session-end)
  "After session end"
),
:ensure(
  greater-than-or-equal-to(oracle-publish-time oracle-session-start)
  "Price before session start"
),

/* Safety guard: zero price means something is fundamentally broken
 * (bad encoding, uninitialised data, server bug). Allowing it would
 * give away tokens for free. */
:ensure(
  greater-than(oracle-price 0)
  "Oracle price is zero"
),

/* Safety guard: minimum price bound. Configurable floor per asset to
 * catch catastrophic mispricings (penny-stock at $0.01, blue chip at
 * $10, etc.). Redundant with the pair bind above for the swapped-frame
 * case, but still useful for a compromised signer or model regression
 * that returns an in-band but wrong price for the correct pair.
 * Inclusive: a price exactly at `min-price` matches the UI's "below
 * this reverts" wording. */
:ensure(
  greater-than-or-equal-to(oracle-price min-price)
  "Price below minimum bound"
),

/* Safety guard: maximum price bound. Configurable ceiling per asset
 * to catch overflow or encoding errors. Inclusive: same reasoning. */
:ensure(
  less-than-or-equal-to(oracle-price max-price)
  "Price above maximum bound"
),

max-output: max-positive-value(),
ratio: oracle-price;

#handle-io
:;

#handle-add-order
:;
