# Edit via `nix develop -c tf-edit-vars` — the helper decrypts the
# .age file, opens $EDITOR, and re-encrypts on exit. Never commit the
# plaintext `terraform.tfvars`.

do_token = "REPLACE_WITH_DO_API_TOKEN"

# Optional overrides; defaults from variables.tf shown commented out:
