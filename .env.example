SIGNER_PRIVATE_KEY=0x...
# st0x.pricing API key (Bearer auth). Format `pricing_<consumer>_<32 hex>`;
# the consumer name must match the `[pricing].consumer` value in
# config.toml. Live `Quote`s arrive over the WebSocket — the oracle
# no longer polls Alpaca for reference prices.
PRICING_API_KEY=pricing_oracle_...
# Alpaca Broker API creds (HTTP Basic auth). Used only for the
# trading-calendar endpoint that powers MarketHoursCache (RAI-693).
# The brokerage account id is no longer needed.
ALPACA_API_KEY_ID=...
ALPACA_API_SECRET_KEY=...
# Optional override; defaults to ./config.toml
CONFIG_PATH=config.toml
