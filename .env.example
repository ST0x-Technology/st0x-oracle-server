# Signer: set EXACTLY ONE of the two.
#
# Production: GCP Cloud KMS key VERSION resource name. The key never leaves
# KMS. Requires Application Default Credentials with cloudkms.signerVerifier
# on the key — native on GCP runtimes (Cloud Run attached service account);
# anywhere else you must provide ADC yourself (e.g.
# GOOGLE_APPLICATION_CREDENTIALS). Deliberately a placeholder here: never
# point a local .env at the production key.
#SIGNER_KMS_KEY=projects/<project-id>/locations/<region>/keyRings/<keyring>/cryptoKeys/<key>/cryptoKeyVersions/<version>
#
# Local dev / tests:
#SIGNER_PRIVATE_KEY=0x...

# Alpaca Broker API creds (HTTP Basic auth) — we read reference prices
# from the issuer's brokerage positions, not from the Market Data API.
ALPACA_API_KEY_ID=...
ALPACA_API_SECRET_KEY=...
# Brokerage account ID whose positions back the oracle. Must hold every
# symbol in config.toml or startup will fail loud.
ALPACA_BROKER_ACCOUNT_ID=...
# Optional override; defaults to ./config.toml
CONFIG_PATH=config.toml
