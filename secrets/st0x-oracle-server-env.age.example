# Placeholder for the encrypted `secrets/st0x-oracle-server-env.age`.
# The plaintext is an `EnvironmentFile`-shape blob (KEY=value per line)
# loaded into the systemd service via `EnvironmentFile=` in os.nix.
#
# Required fields (post-RAI-360 — live quotes come from st0x.pricing
# over the tailnet, so the broker positions endpoint is no longer
# polled. Only the Alpaca trading-calendar endpoint is hit, hence
# ALPACA_API_KEY_ID + ALPACA_API_SECRET_KEY are kept and
# ALPACA_BROKER_ACCOUNT_ID is dropped):
#
#   SIGNER_PRIVATE_KEY=0x...64-hex...           # ETH key that signs each context
#   PRICING_API_KEY=pricing_oracle_<32-hex>     # Matches PRICING_API_KEYS on st0x.pricing
#   ALPACA_API_KEY_ID=...                       # Alpaca broker API key id (calendar only)
#   ALPACA_API_SECRET_KEY=...                   # Alpaca broker API secret
#   RUST_LOG=st0x_oracle_server=info,warn
#
# Create with:
#
#   cat > /tmp/st0x-oracle-server-env <<'EOF'
#   SIGNER_PRIVATE_KEY=0x...
#   PRICING_API_KEY=pricing_oracle_...
#   ALPACA_API_KEY_ID=...
#   ALPACA_API_SECRET_KEY=...
#   RUST_LOG=st0x_oracle_server=info,warn
#   EOF
#
#   nix eval --raw --file ../keys.nix roles.ssh \
#     --apply 'builtins.concatStringsSep "\n"' \
#     | rage -e -R /dev/stdin -o secrets/st0x-oracle-server-env.age /tmp/st0x-oracle-server-env
#
#   rm /tmp/st0x-oracle-server-env
